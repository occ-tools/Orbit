{
  "name": "orbit-autocomplete",
  "displayName": "Orbit Autocomplete",
  "description": "VS Code inline completions provider powered by local Orbit Autocomplete server",
  "version": "0.1.6",
  "publisher": "orbit-ai",
  "engines": {
