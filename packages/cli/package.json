{
  "name": "@orbit-build/cli",
  "version": "0.1.9",
  "description": "Local-first AI coding agent CLI, TUI, Web UI, diagnostics, and LSP runtime",
  "keywords": [
    "ai",
    "coding-agent",
    "cli",
    "deepseek",
    "lsp"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hephaestus-DevKit/Orbit.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/Hephaestus-DevKit/Orbit#readme",
  "bugs": {
    "url": "https://github.com/Hephaestus-DevKit/Orbit/issues"
  },
  "bin": {
    "orbit": "dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "picocolors": "^1.0.1",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "yaml": "^2.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@orbit-build/shared": "workspace:*",
    "@orbit-build/config": "workspace:*",
    "@orbit-build/core": "workspace:*",
    "@orbit-build/tui": "workspace:*",
    "@orbit-build/model-providers": "workspace:*",
    "@orbit-build/context-engine": "workspace:*",
    "@orbit-build/permissions": "workspace:*",
    "@orbit-build/session": "workspace:*",
    "@orbit-build/sandbox": "workspace:*"
  }
}
